rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function canReadChat(chatId) {
      return signedIn() && (
        get(/databases/$(database)/documents/chats/$(chatId)).data.isPublic == true ||
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
      );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if signedIn() && (
        resource.data.isPublic == true ||
        request.auth.uid in resource.data.participants
      );

      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.participants;

      allow update: if signedIn() && request.auth.uid in resource.data.participants;
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if canReadChat(chatId);

      allow create: if canReadChat(chatId)
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 3000;

      allow update, delete: if false;
    }
  }
}